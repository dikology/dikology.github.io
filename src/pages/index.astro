---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';

const allPosts = await Astro.glob('./posts/*.md');
const pageTitle = "Home Page";
---
<Layout title={pageTitle}>
  <ul>
    {allPosts.map((post) => (
      <Card
        href={post.url ?? '#'} // Default to '#' if undefined
        title={post.frontmatter.title ?? 'Untitled'} // Default to 'Untitled' if undefined
        body={post.frontmatter.description ?? 'No description available'} // Default body text
      />
    ))}
    
  </ul>
</Layout>