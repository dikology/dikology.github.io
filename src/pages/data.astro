---
import Layout from "../layouts/Layout.astro";

const pageTitle = "data";
---

<Layout title={pageTitle}>
  <section class="download-section">
    <h1>Download Latest Deck</h1>
    <p>Get the latest Anki deck generated by our GitHub Actions pipeline.</p>
    <a href="https://github.com/YOUR_REPO/actions" target="_blank" class="download-button">Go to GitHub Actions</a>
  </section>

  <section class="notebook-gallery">
    <h1>Portfolio Notebook Gallery</h1>
    <p>Explore interactive Jupyter Notebooks dynamically loaded using JupyterLite or Binder.</p>
    <div class="notebook-grid">
      <a href="https://mybinder.org/v2/gh/YOUR_REPO/BRANCH?filepath=notebook1.ipynb" target="_blank" class="notebook-card">
        <h2>Notebook 1</h2>
        <p>Description of notebook 1.</p>
      </a>
      <a href="https://mybinder.org/v2/gh/YOUR_REPO/BRANCH?filepath=notebook2.ipynb" target="_blank" class="notebook-card">
        <h2>Notebook 2</h2>
        <p>Description of notebook 2.</p>
      </a>
      <!-- Add more notebook cards as needed -->
    </div>
  </section>
</Layout>
