---
const galleryPosts = await Astro.glob('../pages/posts/gallery/*.md');

// Get current URL path
const currentPath = Astro.url.pathname;

// Filter out current post if we're on a specific post page
const filteredPosts = galleryPosts.filter(post => {
  const postPath = `/gallery-2/${encodeURIComponent(post.frontmatter.title)}`;
  // Ensure both paths are absolute and normalized
  return currentPath !== postPath && currentPath !== postPath + '/';
});

// Helper function to split posts into 4 columns - modified for even distribution
function chunkPosts(posts: any[], numColumns: number): any[][] {
  const columns: any[][] = Array.from({ length: numColumns }, () => []);
  posts.forEach((post) => {
    // Use the original index stored in frontmatter or calculate a stable hash from the title
    const columnIndex = Math.abs(hashString(post.frontmatter.title)) % numColumns;
    columns[columnIndex].push(post);
  });
  return columns;
}

// Simple string hashing function
function hashString(str: string): number {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    const char = str.charCodeAt(i);
    hash = (hash * 31 + char) >>> 0; // Using unsigned right shift for better distribution
  }
  return hash;
}

const columns = chunkPosts(filteredPosts, 4);
---

<section class="grid grid-cols-2 md:grid-cols-4 gap-4">
  {columns.map((column) => (
    <div class="grid gap-4">
      {column.map((post) => (
        <div transition:name={`wrapper-${post.frontmatter.title}`}>
          <a href={`/gallery-2/${encodeURIComponent(post.frontmatter.title)}`}>
            <img
              class="h-auto max-w-full rounded-lg"
              src={post.frontmatter.image}
              alt={post.frontmatter.title}
              transition:name={post.frontmatter.title}
            />
          </a>
        </div>
      ))}
    </div>
  ))}
</section>

<style>
  .grid {
    align-items: start;
  }
</style>