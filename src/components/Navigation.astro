---
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
---

<div class="Astronav">
  <Astronav>
    <div class="flex justify-between">
      <MenuIcon class="MenuIcon" />
    </div>
    <MenuItems class="MenuItems hidden lg:flex">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/gallery-2">Gallery</a></li>
        <li><a href="/sailboating">Sailboating</a></li>
        <li><a href="/data">Data</a></li>
      </ul>
    </MenuItems>
  </Astronav>
</div>

<style>
/* Base Navigation Styles */
.Astronav {
  background: var(--primary-color);
  backdrop-filter: blur(8px);
  padding: var(--spacing-medium) var(--spacing-large);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--border-color);
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.5);
  position: sticky;
  top: 0;
  z-index: 1000;
}

/* Logo Styles */
.Astronav a {
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--text-color);
  text-decoration: none;
  transition: color 0.3s ease;
}

.Astronav a:hover {
  color: var(--accent-color); 
}

/* Menu Items */
.MenuItems ul {
  display: flex;
  gap: 2.5rem; 
  padding: 0;
  margin: 0;
  list-style-type: none;
}

.MenuItems ul li {
  position: relative;
}

.MenuItems ul li a {
  font-size: 1.2rem;
  font-weight: 500;
  color: var(--text-color);
  text-decoration: none;
  transition: all 0.3s ease;
}

.MenuItems ul li a:hover {
  color: var(--accent-color); 
}

.MenuItems ul li a::after {
  content: '';
  position: absolute;
  width: 0%;
  height: 2px;
  background: var(--accent-color); 
  bottom: -5px;
  left: 0;
  transition: width 0.3s ease;
}

.MenuItems ul li a:hover::after {
  width: 100%;
}

/* Mobile Styles */
.MenuIcon {
  display: block;
  cursor: pointer;
  color: var(--text-color);
  font-size: 1.5rem;
  transition: color 0.3s ease;
}

.MenuIcon:hover {
  color: #ffffff; 
}

/* Default for small screens: Hide the menu items and show the icon */
@media (max-width: 1023px) {
  .Astronav {
    flex-direction: column;
    align-items: flex-end;
  }

  .MenuItems {
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .MenuItems ul {
    flex-direction: column;
    gap: 1rem;
  }

  .MenuIcon {
    display: block; /* Show the menu icon */
  }

  .MenuItems.open {
    display: flex; /* Show the menu when it's toggled open */
  }
}

/* Desktop Styles: Show menu items, hide icon */
@media (min-width: 1024px) {
  .MenuItems {
    display: flex;
  }

  .MenuIcon {
    display: none; /* Hide the menu icon on larger screens */
  }
}
</style>
