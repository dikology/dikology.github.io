#!/bin/bash
echo "Running pre-commit hook: Checking for changes in 'src/pages/posts/analytics'..."

# Check if there are changes in the target folder
CHANGED_FILES=$(git diff --cached --name-only | grep '^src/pages/posts/analytics/')

if [ -n "$CHANGED_FILES" ]; then
    echo "Changes detected in 'src/pages/posts/analytics'. Generating Anki deck..."
    
    # Run the Python script
    poetry run python utils/generate_anki.py

    # Wait for the file to be created
    if [ -f "public/decks/analytics.apkg" ]; then
        # Stage the generated file
        git add public/decks/analytics.apkg
        echo "Anki deck generated and staged."
    else
        echo "Error: Anki deck was not generated. Aborting commit."
        exit 1
    fi

    echo "Anki deck generated and staged."
else
    echo "No changes detected in 'src/pages/posts/analytics'. Skipping Anki deck generation."
    # exit 0
fi

# Run Prettier for formatting
echo "Running Prettier..."
npx prettier --write --ignore-path .gitignore $(git diff --cached --name-only)

# Run ESLint for linting (only on staged files)
echo "Running ESLint..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d | grep -E '\.(js|jsx|ts|tsx)$' || true)
if [ -n "$STAGED_FILES" ]; then
    npx eslint ${STAGED_FILES} --fix

    # Add back the modified files to staging
    git add ${STAGED_FILES}
fi

if [ $? -ne 0 ]; then
    echo "Linting failed. Aborting commit."
    exit 1
fi

# Check for staged changes in the pages/posts/ directory
if git diff --cached --name-only | grep -q "^src/pages/posts/"; then
   echo "✅ At least one file in 'pages/posts/' is updated."
else
   echo "❌ You must update at least one file in the 'pages/posts/' directory before committing."
   exit 1
fi

echo "Code formatting and linting completed successfully."
echo "Pre-commit hook completed."
